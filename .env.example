# --- Cost control ---
# Default (unset/false) = 100% free: the whole pipeline runs on-device (Whisper,
# ffmpeg, librosa, Pillow) and makes NO paid Claude/Gemini calls. Set to true only
# to opt in to the paid AI stages (song ID, AI clip brains, AI thumbnails, LLM captions).
USE_PAID_APIS=false

# API keys are only used when USE_PAID_APIS=true. Safe to leave set; they cost nothing unused.
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite:///./data/db.sqlite
DATA_DIR=./data
CORS_ORIGINS=http://localhost:5173
